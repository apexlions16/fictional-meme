{
  "name": "fictional-meme",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "release:check": "npm run typecheck && npm run build",
    "preversion": "npm run release:check",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\"",
    "desktop:prepare": "node scripts/prepare-desktop.mjs",
    "desktop:windows:x64": "node scripts/build-windows-exe.mjs amd64",
    "desktop:windows:arm64": "node scripts/build-windows-exe.mjs arm64",
    "desktop:windows": "npm run build && npm run desktop:prepare && npm run desktop:windows:x64 && npm run desktop:windows:arm64"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "description": "Hayalî karakterler ve evrenler için gelişmiş, tarayıcı tabanlı meme üretim stüdyosu.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  }
}
